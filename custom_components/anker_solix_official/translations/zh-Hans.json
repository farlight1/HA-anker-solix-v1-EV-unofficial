  "exceptions": {
    "charge_power_too_low": {
      "message": "当前设备可充电功率仅为 {power} W（最低要求 100 W），无法设置充电功率，请检查设备。"
    },
    "discharge_power_too_low": {
      "message": "当前设备可放电功率仅为 {power}W（最低要求 100W），无法设置放电功率，请检查设备。"
    },
