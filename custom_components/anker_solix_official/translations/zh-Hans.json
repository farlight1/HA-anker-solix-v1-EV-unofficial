      "message": "{entity} 的值 {value}% 必须大于 {target}（{target_value}%）。请调整设置。"
    },
    "soc_must_be_greater_than_or_equal": {
      "message": "{entity} 的值 {value}% 必须大于或等于 {target}（{target_value}%）。请调整设置。"
    },
    "soc_must_be_less_than": {
      "message": "{entity} 的值 {value}% 必须小于 {target}（{target_value}%）。请调整设置。"
    },
    "soc_must_be_less_than_or_equal": {
      "message": "{entity} 的值 {value}% 必须小于或等于 {target}（{target_value}%）。请调整设置。"
    },
    "write_condition_not_met": {
      "message": "无法设置此值，因为未满足所需条件。请检查设备状态。"
    },
    "enable_backup_soc_first": {
      "message": "此功能需要在 Anker APP 的设置中启用备电保留开关。"
