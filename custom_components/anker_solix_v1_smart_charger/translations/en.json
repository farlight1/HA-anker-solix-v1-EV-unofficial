{
  "config": {
    "step": {
      "user": {
        "title": "Anker Solix",
        "description": "Please enter the IP address of the Anker Solix device (default port 502 will be used automatically)",
        "data": {
          "ip_address": "IP Address"
        }
      }
    },
    "abort": {
      "already_configured": "This IP address is already configured"
    },
    "error": {
      "unknown": "Unknown error occurred",
      "cannot_connect": "Cannot connect to device via Modbus. Please check if the IP address is correct, the device is online, and Modbus TCP is enabled on port 502",
      "invalid_ip": "Invalid IPv4 address format. Please enter a valid IPv4 address (e.g., 192.168.1.100)",
      "device_not_supported": "Device not supported. Unable to find matching configuration file for this device model.",
      "connection_timeout": "Connection timeout. Please check if the device is online and accessible"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Anker Solix Options",
        "description": "Configure Anker Solix options"
      }
    }
  },
  "exceptions": {
    "charge_power_too_low": {
      "message": "The device's available charging power is only {power} W (minimum required: 100 W), so the charging power cannot be set. Please check the device."
    },
    "discharge_power_too_low": {
      "message": "The device's available discharging power is only {power}W (minimum required: 100W), unable to set discharging power, please check the device."
    },
    "soc_must_be_greater_than": {
      "message": "The {entity} value {value}% must be greater than {target} ({target_value}%). Please adjust the settings."
    },
    "soc_must_be_greater_than_or_equal": {
      "message": "The {entity} value {value}% must be greater than or equal to {target} ({target_value}%). Please adjust the settings."
    },
    "soc_must_be_less_than": {
      "message": "The {entity} value {value}% must be less than {target} ({target_value}%). Please adjust the settings."
    },
    "soc_must_be_less_than_or_equal": {
      "message": "The {entity} value {value}% must be less than or equal to {target} ({target_value}%). Please adjust the settings."
    },
    "write_condition_not_met": {
      "message": "Cannot set this value because the required condition is not met. Please check the device status."
    },
    "enable_backup_soc_first": {
      "message": "This feature requires enabling the Backup Reserve switch in the Anker app under Settings."
    },
    "power_range_1_to_99_not_allowed": {
      "message": "Power cannot be set in the {forbidden_min}-{forbidden_max}W range. Please set 0W or {allowed_min}-{allowed_max}W."
    }
  },
