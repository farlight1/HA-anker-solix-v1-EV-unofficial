  "exceptions": {
    "charge_power_too_low": {
      "message": "La puissance de charge disponible de l'appareil n'est que de {power} W (minimum requis : 100 W), la puissance de charge ne peut donc pas être réglée. Veuillez vérifier l'appareil."
    },
    "discharge_power_too_low": {
      "message": "La puissance de décharge disponible de l'appareil n'est que de {power}W (minimum requis : 100W), impossible de régler la puissance de décharge, veuillez vérifier l'appareil."
    },
    "soc_must_be_greater_than": {
      "message": "La valeur {entity} de {value}% doit être supérieure à {target} ({target_value}%). Veuillez ajuster les réglages."
    },
    "soc_must_be_greater_than_or_equal": {
      "message": "La valeur {entity} de {value}% doit être supérieure ou égale à {target} ({target_value}%). Veuillez ajuster les réglages."
    },
    "soc_must_be_less_than": {
      "message": "La valeur {entity} de {value}% doit être inférieure à {target} ({target_value}%). Veuillez ajuster les réglages."
    },
    "soc_must_be_less_than_or_equal": {
      "message": "La valeur {entity} de {value}% doit être inférieure ou égale à {target} ({target_value}%). Veuillez ajuster les réglages."
    },
    "write_condition_not_met": {
      "message": "Impossible de définir cette valeur car la condition requise n'est pas remplie. Veuillez vérifier l'état de l'appareil."
    },
    "enable_backup_soc_first": {
      "message": "Cette fonctionnalité nécessite d'activer l'interrupteur de réserve de secours dans les paramètres de l'application Anker."
    },
    "power_range_1_to_99_not_allowed": {
      "message": "La puissance ne peut pas être réglée dans la plage de {forbidden_min}-{forbidden_max}W. Veuillez régler 0W ou {allowed_min}-{allowed_max}W."
    }
  },
