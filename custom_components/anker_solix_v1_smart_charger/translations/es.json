      "message": "El valor de {entity} ({value}%) debe ser menor que {target} ({target_value}%). Por favor, ajusta la configuración."
    },
    "soc_must_be_less_than_or_equal": {
      "message": "El valor de {entity} ({value}%) debe ser menor o igual que {target} ({target_value}%). Por favor, ajusta la configuración."
    },
